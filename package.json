{
  "name": "slack-topic-keeper",
  "version": "0.1.0",
  "description": "Obsidian plugin: Slack Topic Keeper",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs --production",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "esbuild": "^0.21.0",
    "eslint": "^9.0.0",
    "obsidian": "1.12.3",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.6.1"
  }
}
